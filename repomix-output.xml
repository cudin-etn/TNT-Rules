// /src/app/api/ai-chat/route.ts
import { NextResponse } from "next/server";
import { createClient } from "@supabase/supabase-js";

type ProductRow = {
  id: string | number;
  name?: string | null;
  slug?: string | null;
  price?: number | string | null;
  category?: string | null;
  description?: string | null;
  images?: unknown;
  image_url?: unknown;
};

type ChatReq = {
  message: string;
  locale?: string;
  mode?: "demo" | "live";
};

type Suggestion = {
  id?: string | number;
  name: string;
  slug?: string | null;
  price?: number;
  image?: string;
  reason?: string;
};

function getFirstImageUrl(images: unknown): string | undefined {
  const fallback = "/images/placeholder.png";
  if (!images) return fallback;

  if (Array.isArray(images)) {
    const first = images.find((x) => typeof x === "string" && x.trim() !== "");
    return typeof first === "string" ? first.trim() : fallback;
  }

  if (typeof images === "string") {
    const s = images.trim();
    if (!s) return fallback;

    if (s.startsWith("[") && s.endsWith("]")) {
      try {
        const parsed = JSON.parse(s);
        if (Array.isArray(parsed)) {
          const first = parsed.find((x) => typeof x === "string" && x.trim() !== "");
          return typeof first === "string" ? first.trim() : fallback;
        }
      } catch {
        // fall through
      }
    }

    return s;
  }

  return fallback;
}

function toSuggestion(p: ProductRow, reason?: string): Suggestion {
  return {
    id: p.id,
    name: String(p.name ?? "Sản phẩm"),
    slug: p.slug ?? null,
    price: Number(p.price) || 0,
    image: getFirstImageUrl(p.images ?? p.image_url),
    reason,
  };
}

function demoAnswer(message: string, products: ProductRow[]) {
  const picks = products.slice(0, 3).map((p, idx) =>
    toSuggestion(
      p,
      idx === 0
        ? "Phù hợp câu cá lóc/địa hình phổ biến, dễ dùng."
        : idx === 1
        ? "Tạo rung/độ phản quang tốt, dùng được nhiều tình huống."
        : "Dễ phối màu và thay đổi tốc độ thu dây."
    )
  );

  const text =
    `Mình tư vấn nhanh theo nhu cầu anh/chị nhé:\n` +
    `• Anh/chị câu hồ hay sông? Nước đục hay trong? Nhắm cá lóc/cá rô/cá chẽm?\n\n` +
    `Dựa trên câu hỏi: “${message}”, em gợi ý 3 lựa chọn dễ trúng:\n` +
    picks
      .map(
        (s, i) =>
          `${i + 1}) ${s.name} — ${Number(s.price || 0).toLocaleString("vi-VN")} ₫` +
          (s.reason ? ` (${s.reason})` : "")
      )
      .join("\n") +
    `\n\nMuốn em chốt nhanh: anh/chị cho em ngân sách (vd 300k/500k) và loại cá mục tiêu ạ.`;

  return { text, suggestions: picks };
}

async function fetchProductsForRag(query: string) {
  const supabaseUrl = process.env.NEXT_PUBLIC_SUPABASE_URL;
  const serviceKey =
    process.env.SUPABASE_SERVICE_ROLE_KEY || process.env.NEXT_PUBLIC_SUPABASE_ANON_KEY;

  if (!supabaseUrl || !serviceKey) {
    return { products: [] as ProductRow[], note: "Missing Supabase env" };
  }

  const supabase = createClient(supabaseUrl, serviceKey, {
    auth: { persistSession: false },
  });

  // Simple keyword search. For demo: query name/slug/category.
  // (If you have tsvector/fulltext later, replace this.)
  const kw = query.trim();
  const { data, error } = await supabase
    .from("products")
    .select("id,name,slug,price,category,description,images,image_url")
    .or(`name.ilike.%${kw}%,slug.ilike.%${kw}%,category.ilike.%${kw}%`)
    .limit(12);

  if (error || !data) return { products: [] as ProductRow[], note: error?.message ?? "No data" };

  // If query too short and returns empty, just grab top products
  if (data.length === 0) {
    const { data: fallback } = await supabase
      .from("products")
      .select("id,name,slug,price,category,description,images,image_url")
      .limit(12);
    return { products: (fallback ?? []) as ProductRow[], note: "fallback" };
  }

  return { products: data as ProductRow[], note: "matched" };
}

async function callOpenAI(userMessage: string, products: ProductRow[]) {
  const apiKey = process.env.OPENAI_API_KEY;
  if (!apiKey) {
    return {
      text:
        "Chưa cấu hình OPENAI_API_KEY nên đang chạy demo mode. Anh/chị vào Settings > env để bật live.",
      suggestions: products.slice(0, 3).map((p) => toSuggestion(p)),
    };
  }

  // Keep context small for speed + cost
  const context = products.slice(0, 8).map((p) => ({
    id: p.id,
    name: p.name,
    slug: p.slug,
    price: Number(p.price) || 0,
    category: p.category,
    description: p.description,
  }));

  const system = `
Bạn là nhân viên tư vấn bán hàng cho shop mồi câu (TNT Lures).
Nhiệm vụ:
- Tư vấn đúng nhu cầu, hỏi 1-2 câu làm rõ nếu thiếu thông tin (loại cá, địa hình, nước đục/trong, thời điểm).
- KHÔNG bịa giá/sản phẩm. Chỉ được đề xuất trong danh sách "SẢN PHẨM CÓ SẴN".
- Luôn trả về JSON theo schema yêu cầu.
Schema JSON:
{
  "reply": "string",
  "suggestions": [
    { "id": "string|number", "name": "string", "slug": "string|null", "price": number, "reason": "string" }
  ]
}
Giới hạn suggestions: 3 mục.
`.trim();

  const user = `
CÂU HỎI KHÁCH: ${userMessage}

SẢN PHẨM CÓ SẴN (chỉ được chọn từ đây):
${JSON.stringify(context, null, 2)}
`.trim();

  // Use Responses API (recommended). If your project uses older API, adjust accordingly.
  const resp = await fetch("https://api.openai.com/v1/responses", {
    method: "POST",
    headers: {
      Authorization: `Bearer ${apiKey}`,
      "Content-Type": "application/json",
    },
    body: JSON.stringify({
      model: process.env.OPENAI_MODEL || "gpt-4.1-mini",
      input: [
        { role: "system", content: [{ type: "text", text: system }] },
        { role: "user", content: [{ type: "text", text: user }] },
      ],
      temperature: 0.4,
      max_output_tokens: 450,
    }),
  });

  if (!resp.ok) {
    const errText = await resp.text();
    return {
      text: `AI live đang lỗi (${resp.status}). Chuyển sang demo.\n${errText.slice(0, 200)}`,
      suggestions: products.slice(0, 3).map((p) => toSuggestion(p)),
    };
  }

  const json = await resp.json();

  // Extract model text output (Responses API)
  const outputText: string =
    json?.output?.[0]?.content?.find((c: any) => c.type === "output_text")?.text ??
    json?.output_text ??
    "";

  // Try parse JSON from model
  let parsed: any = null;
  try {
    parsed = JSON.parse(outputText);
  } catch {
    // If the model returns non-pure JSON, try to find the first JSON block
    const match = outputText.match(/\{[\s\S]*\}$/);
    if (match) {
      try {
        parsed = JSON.parse(match[0]);
      } catch {
        parsed = null;
      }
    }
  }

  if (!parsed?.reply) {
    return {
      text: outputText || "AI trả lời nhưng không đúng format. Chuyển demo.",
      suggestions: products.slice(0, 3).map((p) => toSuggestion(p)),
    };
  }

  const suggestions: Suggestion[] = Array.isArray(parsed.suggestions)
    ? parsed.suggestions.slice(0, 3).map((s: any) => {
        const price = Number(s.price) || 0;
        // Try map back to product image
        const found = products.find((p) => String(p.id) === String(s.id) || p.slug === s.slug);
        return {
          id: s.id,
          name: String(s.name ?? found?.name ?? "Sản phẩm"),
          slug: s.slug ?? found?.slug ?? null,
          price,
          reason: typeof s.reason === "string" ? s.reason : undefined,
          image: found ? getFirstImageUrl(found.images ?? found.image_url) : "/images/placeholder.png",
        };
      })
    : products.slice(0, 3).map((p) => toSuggestion(p));

  return { text: String(parsed.reply), suggestions };
}

export async function POST(req: Request) {
  const body = (await req.json().catch(() => null)) as ChatReq | null;
  const message = body?.message?.trim();
  const mode = body?.mode ?? "demo";

  if (!message) {
    return NextResponse.json(
      { error: "Missing message" },
      { status: 400 }
    );
  }

  // RAG: fetch products relevant to message
  const { products } = await fetchProductsForRag(message);

  // If no products at all, still answer
  if (mode === "live") {
    const live = await callOpenAI(message, products);
    return NextResponse.json(live);
  }

  const demo = demoAnswer(message, products);
  return NextResponse.json(demo);
}
