"use client";

import { useMemo, useState } from "react";
import { MessageSquare, Search, Send, Sparkles, PlugZap } from "lucide-react";
import { Link } from "@/i18n/routing";

type Channel = "Zalo" | "Facebook" | "Instagram" | "Website";

type Conv = {
  id: string;
  name: string;
  channel: Channel;
  lastMsg: string;
  time: string;
  unread: number;
};

type Msg = { from: "customer" | "agent"; text: string; time: string };

const mockConvs: Conv[] = [
  { id: "c1", name: "Anh Khoa", channel: "Zalo", lastMsg: "Câu cá lóc hồ nước đục dùng mồi nào?", time: "10:21", unread: 2 },
  { id: "c2", name: "Chị Linh", channel: "Facebook", lastMsg: "Cho xin combo 500k nhé", time: "09:58", unread: 0 },
  { id: "c3", name: "Nam", channel: "Instagram", lastMsg: "Mồi nhái hơi size 8cm còn không?", time: "Hôm qua", unread: 1 },
];

const mockMsgs: Record<string, Msg[]> = {
  c1: [
    { from: "customer", text: "Câu cá lóc hồ nước đục dùng mồi nào?", time: "10:20" },
    { from: "customer", text: "Em tư vấn giúp anh 2–3 mẫu nhé", time: "10:21" },
    { from: "agent", text: "Dạ anh cho em biết câu sáng hay chiều ạ? Anh ưu tiên mồi nổi hay chìm?", time: "10:21" },
  ],
  c2: [
    { from: "customer", text: "Cho xin combo 500k nhé", time: "09:58" },
    { from: "agent", text: "Dạ em gợi ý combo 3 món: nhái hơi + cá sắt + mồi mềm, em gửi list ngay ạ.", time: "10:00" },
  ],
  c3: [
    { from: "customer", text: "Mồi nhái hơi size 8cm còn không?", time: "Hôm qua" },
    { from: "agent", text: "Dạ còn anh ạ. Anh cần màu tự nhiên hay màu nổi?", time: "Hôm qua" },
  ],
};

export default function AdminChatPage() {
  const [q, setQ] = useState("");
  const [active, setActive] = useState<Conv>(mockConvs[0]);
  const [text, setText] = useState("");

  const convs = useMemo(() => {
    const kw = q.trim().toLowerCase();
    return mockConvs.filter((c) => !kw || c.name.toLowerCase().includes(kw) || c.lastMsg.toLowerCase().includes(kw));
  }, [q]);

  const msgs = mockMsgs[active.id] ?? [];

  return (
    <div className="space-y-4">
      <div>
        <h1 className="text-2xl font-bold tracking-tight text-slate-900 dark:text-white">
          Chat đa kênh
        </h1>
        <p className="text-xs font-semibold text-slate-600 dark:text-slate-300 mt-1">
          UI inbox hợp nhất (mock). Tích hợp thật sẽ làm ở phase đa kênh.
        </p>
      </div>

      <div className="grid grid-cols-1 lg:grid-cols-[320px_1fr] gap-4">
        {/* Left: Conversation list */}
        <div className="rounded-3xl border border-white/40 dark:border-white/10 bg-white/60 dark:bg-slate-900/50 backdrop-blur-xl shadow-sm overflow-hidden">
          <div className="p-3 border-b border-white/40 dark:border-white/10">
            <div className="relative">
              <Search className="absolute left-3 top-1/2 -translate-y-1/2 h-4 w-4 text-slate-400" />
              <input
                value={q}
                onChange={(e) => setQ(e.target.value)}
                placeholder="Tìm hội thoại..."
                className="w-full h-10 pl-10 pr-3 rounded-2xl bg-white/70 dark:bg-white/5 border border-white/50 dark:border-white/10 outline-none text-[13px]"
              />
            </div>
          </div>

          <div className="max-h-[560px] overflow-y-auto">
            {convs.map((c) => {
              const isActive = c.id === active.id;
              return (
                <button
                  key={c.id}
                  onClick={() => setActive(c)}
                  className={`w-full text-left p-3 border-b border-white/40 dark:border-white/10 transition ${
                    isActive ? "bg-white/70 dark:bg-white/5" : "hover:bg-white/50 dark:hover:bg-white/5"
                  }`}
                >
                  <div className="flex items-start justify-between gap-3">
                    <div className="min-w-0">
                      <div className="font-semibold text-[13px] text-slate-900 dark:text-white truncate">{c.name}</div>
                      <div className="text-xs font-semibold text-slate-500 dark:text-slate-400 truncate">{c.lastMsg}</div>
                      <div className="mt-2 inline-flex items-center gap-2 text-[10px] font-semibold px-2 py-1 rounded-full border bg-slate-900/5 dark:bg-white/5 border-white/40 dark:border-white/10">
                        <MessageSquare className="h-3.5 w-3.5 text-purple-500" />
                        {c.channel}
                      </div>
                    </div>
                    <div className="text-right shrink-0">
                      <div className="text-[11px] font-semibold text-slate-400">{c.time}</div>
                      {c.unread > 0 && (
                        <div className="mt-2 inline-flex h-5 min-w-5 px-2 rounded-full bg-rose-500 text-white text-[11px] font-semibold items-center justify-center">
                          {c.unread}
                        </div>
                      )}
                    </div>
                  </div>
                </button>
              );
            })}
          </div>
        </div>

        {/* Right: Chat */}
        <div className="rounded-3xl border border-white/40 dark:border-white/10 bg-white/60 dark:bg-slate-900/50 backdrop-blur-xl shadow-sm overflow-hidden flex flex-col">
          <div className="p-3 border-b border-white/40 dark:border-white/10 flex items-center justify-between gap-3">
            <div>
              <div className="font-semibold text-[13px] text-slate-900 dark:text-white">{active.name}</div>
              <div className="text-[11px] font-semibold text-slate-500 dark:text-slate-400">
                Kênh: {active.channel} • Demo inbox hợp nhất
              </div>
            </div>
            <button className="h-9 px-3 rounded-xl bg-gradient-to-r from-purple-500 to-fuchsia-500 text-white font-semibold text-[12px] shadow-xl shadow-purple-500/20 hover:shadow-purple-500/40 transition inline-flex items-center gap-2">
              <Sparkles className="h-3.5 w-3.5" />
              <Link
  href="/ai"
  className="h-9 px-3 rounded-xl bg-gradient-to-r from-purple-500 to-fuchsia-500 text-white font-semibold text-[12px] shadow-xl shadow-purple-500/20 hover:shadow-purple-500/40 transition inline-flex items-center gap-2"
>
  <Sparkles className="h-3.5 w-3.5" />
  Gợi ý trả lời (AI)
</Link>
            </button>
          </div>

          <div className="flex-1 p-3 space-y-3 overflow-y-auto">
            {msgs.map((m, idx) => (
              <div
                key={idx}
                className={`max-w-[80%] rounded-2xl px-3 py-2.5 text-[13px] font-medium border ${
                  m.from === "agent"
                    ? "ml-auto bg-orange-500/10 border-orange-500/20 text-slate-900 dark:text-white"
                    : "bg-white/70 dark:bg-white/5 border-white/50 dark:border-white/10 text-slate-900 dark:text-white"
                }`}
              >
                <div>{m.text}</div>
                <div className="mt-1 text-[10px] font-semibold text-slate-500 dark:text-slate-400">{m.time}</div>
              </div>
            ))}
          </div>

          <div className="p-3 border-t border-white/40 dark:border-white/10">
            <div className="mb-3 rounded-2xl border border-white/40 dark:border-white/10 bg-white/60 dark:bg-white/5 px-3 py-2.5 text-[11px] font-semibold text-slate-600 dark:text-slate-300 flex items-center gap-2">
              <PlugZap className="h-3.5 w-3.5 text-amber-500" />
              Tích hợp Zalo/FB/IG thật sẽ làm ở phase đa kênh. Hiện là UI demo.
            </div>

            <div className="flex items-center gap-2">
              <input
                value={text}
                onChange={(e) => setText(e.target.value)}
                placeholder="Nhập tin nhắn..."
                className="flex-1 h-10 px-4 rounded-xl bg-white/70 dark:bg-white/5 border border-white/50 dark:border-white/10 outline-none text-[13px]"
              />
              <button
                onClick={() => setText("")}
                className="h-10 px-4 rounded-xl bg-slate-900 text-white dark:bg-white dark:text-slate-900 font-semibold text-[12px] inline-flex items-center gap-2 hover:opacity-90 transition"
              >
                <Send className="h-3.5 w-3.5" />
                Gửi
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>
  );
}
</file>

